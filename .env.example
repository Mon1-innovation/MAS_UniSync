# Copy this file to .env for local login probing.
# Do not commit real passwords or tokens.

MAS_UNISYNC_ENV=test
# Local/default testing uses SQLite when DATABASE_URL is unset.
# Production must use PostgreSQL.
# DATABASE_URL=postgresql+psycopg://mas_unisync:replace-me@postgres:5432/mas_unisync

FLARUM_URL=https://forum.monika.love/
SESSION_SECRET=replace-with-a-long-random-secret
OBJECT_STORAGE_PATH=./data/objects
LOCK_TTL_SECONDS=60

# Docker Compose PostgreSQL settings. POSTGRES_PASSWORD is required in production.
POSTGRES_DB=mas_unisync
POSTGRES_USER=mas_unisync
POSTGRES_PASSWORD=
BACKEND_PORT=8000
FRONTEND_PORT=80

# Flarum groups that should map to MAS UniSync admin.
# Multiple values are supported with comma, Chinese comma, or semicolon.
ADMIN_FLARUM_GROUP_IDS=16,22
ADMIN_FLARUM_GROUP_NAMES=后台组,管理员组,通用版主组,知识版主组,聊天班主组,站长,创作班主组

# Optional convenience for local testing.
# Leaving the password unset keeps the script on an interactive password prompt.
FLARUM_TEST_IDENTIFICATION=
FLARUM_TEST_PASSWORD=
